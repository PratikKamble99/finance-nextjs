// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?  @map("password_hash")
  googleId     String?  @unique @map("google_id")
  name         String
  currency     String   @default("USD")
  timezone     String   @default("UTC")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  accounts     Account[]
  transactions Transaction[]
  investments  Investment[]
  goals        FinancialGoal[]
  categories   Category[]
  tags         Tag[]
  budgets      Budget[]
  netWorthSnapshots NetWorthSnapshot[]

  @@map("users")
}

model Account {
  id                   String   @id @default(cuid())
  userId               String   @map("user_id")
  name                 String
  type                 AccountType
  bank                 String?
  accountNumber        String?  @map("account_number")
  openingBalance       Decimal  @map("opening_balance") @db.Decimal(15, 2)
  currentBalance       Decimal  @map("current_balance") @db.Decimal(15, 2)
  currency             String
  isActive             Boolean  @default(true) @map("is_active")
  lowBalanceThreshold  Decimal? @map("low_balance_threshold") @db.Decimal(15, 2)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("accounts")
}

model Transaction {
  id               String            @id @default(cuid())
  userId           String            @map("user_id")
  type             TransactionType
  amount           Decimal           @db.Decimal(15, 2)
  currency         String
  date             DateTime
  description      String?
  categoryId       String?           @map("category_id")
  accountId        String?           @map("account_id")
  paymentMode      PaymentMode?      @map("payment_mode")
  location         Json?
  merchant         String?
  receiptUrl       String?           @map("receipt_url")
  isRecurring      Boolean           @default(false) @map("is_recurring")
  recurringPattern Json?             @map("recurring_pattern")
  splits           Json?
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  Account?  @relation(fields: [accountId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])
  tags     TransactionTag[]

  @@map("transactions")
}

model Investment {
  id             String          @id @default(cuid())
  userId         String          @map("user_id")
  assetType      AssetType       @map("asset_type")
  symbol         String
  name           String
  quantity       Decimal         @db.Decimal(15, 6)
  averagePrice   Decimal         @map("average_price") @db.Decimal(15, 2)
  currentPrice   Decimal?        @map("current_price") @db.Decimal(15, 2)
  totalInvested  Decimal         @map("total_invested") @db.Decimal(15, 2)
  currentValue   Decimal?        @map("current_value") @db.Decimal(15, 2)
  realizedPnL    Decimal         @default(0) @map("realized_pnl") @db.Decimal(15, 2)
  unrealizedPnL  Decimal         @default(0) @map("unrealized_pnl") @db.Decimal(15, 2)
  broker         String?
  transactions   Json[]          @default([])
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("investments")
}

model FinancialGoal {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  name              String
  description       String?
  targetAmount      Decimal  @map("target_amount") @db.Decimal(15, 2)
  currentAmount     Decimal  @default(0) @map("current_amount") @db.Decimal(15, 2)
  deadline          DateTime
  category          GoalCategory
  linkedAccounts    String[] @map("linked_accounts")
  linkedInvestments String[] @map("linked_investments")
  monthlyTarget     Decimal? @map("monthly_target") @db.Decimal(15, 2)
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("financial_goals")
}

model Category {
  id           String   @id @default(cuid())
  userId       String?  @map("user_id") // null for system-wide categories
  name         String
  type         TransactionType // INCOME or EXPENSE
  color        String   @default("#6B7280") // hex color code
  icon         String   @default("📁") // emoji or icon name
  isSystem     Boolean  @default(false) @map("is_system") // system predefined categories
  isActive     Boolean  @default(true) @map("is_active")
  parentId     String?  @map("parent_id") // for subcategories
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  user         User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent       Category?    @relation("CategoryHierarchy", fields: [parentId], references: [id])
  subcategories Category[]  @relation("CategoryHierarchy")
  transactions Transaction[]
  budgets      Budget[]

  @@unique([userId, name, type])
  @@map("categories")
}

model Tag {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  name         String
  color        String   @default("#6B7280") // hex color code
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions TransactionTag[]

  @@unique([userId, name])
  @@map("tags")
}

model TransactionTag {
  id            String   @id @default(cuid())
  transactionId String   @map("transaction_id")
  tagId         String   @map("tag_id")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tag         Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([transactionId, tagId])
  @@map("transaction_tags")
}

model Budget {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  categoryId String   @map("category_id")
  amount     Decimal  @db.Decimal(15, 2)
  period     BudgetPeriod
  startDate  DateTime @map("start_date")
  endDate    DateTime @map("end_date")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, period, startDate])
  @@map("budgets")
}

model NetWorthSnapshot {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  date             DateTime
  totalAssets      Decimal  @map("total_assets") @db.Decimal(15, 2)
  totalLiabilities Decimal  @map("total_liabilities") @db.Decimal(15, 2)
  netWorth         Decimal  @map("net_worth") @db.Decimal(15, 2)
  assetBreakdown   Json     @map("asset_breakdown")
  liabilityBreakdown Json   @map("liability_breakdown")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("net_worth_snapshots")
}

// Enums
enum AccountType {
  SAVINGS
  SALARY
  CURRENT
  CASH
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum PaymentMode {
  CASH
  UPI
  CARD
  BANK
}

enum AssetType {
  STOCK
  MUTUAL_FUND
  GOLD
  BOND
  FD
  CRYPTO
}

enum GoalCategory {
  HOUSE
  VACATION
  RETIREMENT
  EDUCATION
  EMERGENCY
  CUSTOM
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}